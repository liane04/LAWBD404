<!DOCTYPE html>
<html lang="pt">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DriveDeal</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/Marketplace.styles.css" asp-append-version="true" />
</head>
<body class="auth-body">
    <!-- Logo Header Minimalista -->
    <div class="auth-header">
        <div class="container">
            <a asp-controller="Home" asp-action="Index" class="auth-logo">
                <img src="~/imagens/logo.png" alt="DriveDeal" height="40">
            </a>
        </div>
    </div>

    <!-- Conteúdo Principal -->
    <main role="main" class="auth-main">
        @RenderBody()
    </main>

    <!-- Footer Minimalista -->
    <footer class="auth-footer">
        <div class="container">
            <div class="text-center">
                <small class="text-muted">
                    &copy; @DateTime.Now.Year DriveDeal - Todos os direitos reservados
                </small>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
